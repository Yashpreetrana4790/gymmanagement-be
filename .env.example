PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/gymmanagement

JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# Email (choose one provider)
# Option 1 — Brevo (300 free/day): https://app.brevo.com/settings/keys/smtp
EMAIL_PROVIDER=brevo
EMAIL_USER=your_brevo_login_email@example.com
EMAIL_PASS=your_brevo_smtp_key
EMAIL_FROM=noreply@yourgym.com

# Option 2 — Gmail (500 free/day, needs App Password)
# EMAIL_PROVIDER=gmail
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx   # 16-char app password from myaccount.google.com/apppasswords
# EMAIL_FROM=you@gmail.com
